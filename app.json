{
  "expo": {
    "name": "Blink",
    "slug": "blink",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "blink",
    "icon": "./assets/brand/blink_app_icon_1024.png",
    "splash": {
      "image": "./assets/brand/blink_app_icon_1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1D33"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.recall.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/blink_adaptive_foreground.png",
        "backgroundColor": "#0F1D33"
      },
      "package": "com.recall.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/brand/blink_app_icon_1024.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Blink usa suas fotos para você escolher uma imagem de perfil."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
